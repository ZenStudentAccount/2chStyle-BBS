// prisma/schema.prisma

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Thread {
  id        Int      @id @default(autoincrement())
  title     String // スレッドタイトル
  createdAt DateTime @default(now())
  posts     Post[]
}

model Post {
  id        Int      @id @default(autoincrement()) // レス番号のベースとなる一意の主キー
  content   String // 投稿本文
  postedBy  String // 投稿者名（未入力時は"名無しさん"）
  ipAddress String // 投稿者のリモートIPアドレス（IPv4/IPv6対応）
  createdAt DateTime @default(now()) // 投稿日時
  thread    Thread   @relation(fields: [threadId], references: [id])
  threadId  Int
}
