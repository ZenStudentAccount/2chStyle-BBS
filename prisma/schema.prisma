// prisma/schema.prisma

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Thread {
  id         Int      @id @default(autoincrement())
  title      String   // スレッドタイトル
  username   String   @default("") // スレッドを作成した認証ユーザー名
  createdAt  DateTime @default(now())
  posts      Post[]
}

model Post {
  id         Int      @id @default(autoincrement()) // レス番号のベースとなる一意の主キー
  content    String   // 投稿本文
  postedBy   String                                 // 投稿者名（未入力時は"名無しさん"）
  ipAddress  String                                 // 投稿者のリモートIPアドレス（IPv4/IPv6対応）
  username   String   @default("")                  // 投稿した認証ユーザー名
  createdAt  DateTime @default(now())               // 投稿日時
  thread     Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  threadId   Int
}
