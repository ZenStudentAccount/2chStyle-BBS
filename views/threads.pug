doctype html
html(lang="ja")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    link(rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      integrity="sha384-9ndCyUaIbzAi2FUVXJi0CjmCapSmO7SnpJef0486qhLnuZ2cdeRhO02iuK6FUUVM"
      crossorigin="anonymous")
    title 2chStyle-BBS - スレッド一覧
    style.
      body {
        padding-top: 70px;
        padding-bottom: 300px;
      }
      .thread-link {
        text-decoration: none;
        color: #0000ee;
        font-size: 1.1rem;
      }
      [data-bs-theme="dark"] .thread-link {
        color: #8888ff;
      }
      .thread-count {
        color: #666;
        font-size: 0.9rem;
      }
      .navbar-brand:hover {
        text-decoration: underline !important;
        opacity: 0.85;
      }
  body(data-bs-theme=currentTheme)
    nav.navbar.fixed-top.navbar-expand-lg.bg-body-tertiary
      div.container-fluid
        a.navbar-brand(href="/threads") 🏠 2chStyle-BBS
        button.navbar-toggler(type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavDropdown")
          span.navbar-toggler-icon
        div#navbarNavDropdown.collapse.navbar-collapse.justify-content-end
          ul.navbar-nav
            li.nav-item.dropdown
              a.nav-link.dropdown-toggle(href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false")
                | #{user}
              ul.dropdown-menu.dropdown-menu-end
                li: a.dropdown-item(href="/changeTheme") テーマ切り替え
                li: a.dropdown-item(href="/logout") ログアウト

    main.container
      h2.mb-4 スレッド一覧
      div.list-group.list-group-flush
        each thread, index in threads
          div.list-group-item.d-flex.align-items-center.justify-content-between
            div
              span.me-2 #{index + 1}:
              a.thread-link(href=`/threads/${thread.id}`) #{thread.title}
              span.ms-2.thread-count (#{thread._count.posts})
            if user === 'admin' || (user === 'guest' && thread.username === 'guest')
              form(method="post" action=`/threads/${thread.id}/deleteThread` style="margin: 0;")
                input(type="hidden" name="csrfToken" value=csrfToken)
                button.btn.btn-outline-danger.btn-sm(type="submit" style="padding: 2px 6px; font-size: 0.8rem; line-height: 1.2;") 削除

    footer.fixed-bottom.bg-body-tertiary.border-top.p-3
      div.container
        h5 新規スレッド作成
        form(method="post" action="/threads")
          input(type="hidden" name="csrfToken" value=csrfToken)
          div.row.mb-2
            div.col-md-4
              input.form-control(type="text" name="title" placeholder="スレッドタイトル" required)
            div.col-md-3
              input.form-control(type="text" name="postedBy" placeholder="名無しさん")
          div.mb-2
            textarea.form-control(name="content" rows="4" placeholder="最初の書き込み" required)
          div.text-end
            button.btn.btn-primary(type="submit") スレッドを立てる

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-geWF76RCwLtnZ8qwWowPQNguL3RmwHVBC9FhGdlKrxdiJJigb/j/68SIy3Te4Bkz"
      crossorigin="anonymous")
