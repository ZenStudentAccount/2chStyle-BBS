doctype html
html(lang="ja")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    link(rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      integrity="sha384-9ndCyUaIbzAi2FUVXJi0CjmCapSmO7SnpJef0486qhLnuZ2cdeRhO02iuK6FUUVM"
      crossorigin="anonymous")
    title #{thread.title} - 2chStyle-BBS
    style.
      body {
        padding-top: 70px;
        padding-bottom: 220px;
      }
      .post-content {
        white-space: pre-wrap;
        margin-left: 2em;
      }
      .post-header {
        font-weight: bold;
        color: #000;
      }
      [data-bs-theme="dark"] .post-header {
        color: #eee;
      }
      .post-author {
        color: green;
      }
      [data-bs-theme="dark"] .post-author {
        color: #90ee90;
      }
      .thread-title {
        color: #ff0000;
        font-size: 1.5rem;
        font-weight: bold;
        margin-bottom: 20px;
      }
      .navbar-brand:hover {
        text-decoration: underline !important;
        opacity: 0.85;
      }
  body(data-bs-theme=currentTheme)
    nav.navbar.fixed-top.navbar-expand-lg.bg-body-tertiary
      div.container-fluid
        a.navbar-brand(href="/threads") 🏠 2chStyle-BBS
        button.navbar-toggler(type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavDropdown")
          span.navbar-toggler-icon
        div#navbarNavDropdown.collapse.navbar-collapse.justify-content-end
          ul.navbar-nav
            li.nav-item.dropdown
              a.nav-link.dropdown-toggle(href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false")
                | #{user}
              ul.dropdown-menu.dropdown-menu-end
                li: a.dropdown-item(href="/changeTheme") テーマ切り替え
                li: a.dropdown-item(href="/logout") ログアウト

    main.container#posts-container
      div.thread-title #{thread.title}
      each post, index in posts
        div.mb-3.border-bottom.pb-2(id=(index === posts.length - 1 ? 'last-post' : undefined))
          div.post-header
            span.me-1 #{index + 1}
            span.me-1
              | 名前：
              span.post-author #{post.postedBy}
            span.me-2 ：#{post.formattedCreatedAt}
            div.d-inline-flex.align-items-center.text-nowrap
              span ID:#{post.displayId}
              if user === 'admin' || (user === 'guest' && post.username === 'guest')
                form(method="post" action=`/threads/${thread.id}/delete` style="display: inline; margin: 0;")
                  input(type="hidden" name="id" value=post.id)
                  input(type="hidden" name="csrfToken" value=csrfToken)
                  button.btn.btn-outline-danger.btn-sm.ms-1(type="submit" style="padding: 0 4px; font-size: 0.7rem; line-height: 1.2;") 削除
          div.post-content.mt-1
            | #{post.content}

    footer.fixed-bottom.bg-body-tertiary.border-top.p-3
      div.container
        form(method="post" action=`/threads/${thread.id}`)
          input(type="hidden" name="csrfToken" value=csrfToken)
          div.row.mb-2
            div.col-md-3
              input.form-control(type="text" name="postedBy" placeholder="名無しさん")
          div.mb-2
            textarea.form-control(name="content" rows="4" placeholder="本文を入力してください" required)
          div.text-end
            button.btn.btn-primary(type="submit") 書き込む

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-geWF76RCwLtnZ8qwWowPQNguL3RmwHVBC9FhGdlKrxdiJJigb/j/68SIy3Te4Bkz"
      crossorigin="anonymous")
    script.
      if (new URLSearchParams(window.location.search).get('last') === 'true') {
        const lastPost = document.getElementById('last-post');
        if (lastPost) {
          lastPost.scrollIntoView({ behavior: 'smooth' });
        }
      }
